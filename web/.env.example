# Absolute or relative path to the azure-resource-downloader output/ tree.
# Default resolves to ../output relative to the api package.
ARD_OUTPUT_DIR=../output

# Port the NestJS API listens on.
PORT=3001

# ---- docgen (only needed to actually generate docs) ----
# LLM provider: anthropic | openai | azure-openai | noop
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Bounded concurrency for LLM calls
DOCGEN_CONCURRENCY=4
